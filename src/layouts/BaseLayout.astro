---
import Head from "@components/Head.astro";

const { title, description, bodyClass } = Astro.props
---

<!doctype html>
<html lang={Astro.currentLocale} class="h-full">
  <Head title={title} description={description}>
    <slot name="structured-data" slot="structured-data" />
  </Head>

  <body class={bodyClass}>
    <slot />
  </body>
</html>

<style>
  @view-transition {
    navigation: auto;
  }
</style>
