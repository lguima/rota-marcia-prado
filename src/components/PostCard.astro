---
import { type CollectionEntry } from "astro:content"
import SiteOptions from "../site.config.mjs"

export interface Props {
  post: CollectionEntry<"article">
  showImage?: boolean
  showCategory?: boolean
}

const { post, showImage = false, showCategory = true } = Astro.props
const { title, pubDate, category, description, author } = post.data

const formattedDate = new Intl.DateTimeFormat(SiteOptions.localization.locale, {
  year: SiteOptions.localization.date.year as Intl.DateTimeFormatOptions['year'],
  month: SiteOptions.localization.date.month as Intl.DateTimeFormatOptions['month'],
  day: SiteOptions.localization.date.day as Intl.DateTimeFormatOptions['day'],
}).format(pubDate)
---

<li class="flex flex-col sm:flex-row justify-between sm:items-center py-4 border-b border-gray-100 dark:border-gray-800">
  <div class="mb-2 sm:mb-0">
    <a href={`/article/${post.slug}`} class="text-xl font-medium hover:underline">
      {title}
      {SiteOptions.showAuthorsOnHomePage && author && <span class="text-sm text-mist-500 dark:text-mist-400 ml-2">{SiteOptions.labels.postedBy} {author}</span>}
    </a>

    {showCategory && category && <span class="ml-0 sm:ml-3 mt-1 sm:mt-0 inline-block text-xs bg-mist-100 text-mist-600 dark:bg-mist-700 dark:text-mist-300 px-2 py-1 rounded">{category}</span>}
    {showImage && description && <p class="text-sm text-mist-500 dark:text-mist-400 mt-1">{description}</p>}
  </div>
  <span class="text-sm text-mist-500 dark:text-mist-400">{formattedDate}</span>
</li>
