---
const { title } = Astro.props
---

<details class="group w-full p-4 [&_summary::-webkit-details-marker]:hidden">
  <summary class="flex cursor-pointer items-center justify-between font-medium list-none">
    <span>{title}</span>
    <span class="transition duration-300 group-open:-rotate-180">
      <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </span>
  </summary>

  <div class="mt-3 text-sm leading-relaxed text-gray-400 border-t border-gray-700 pt-3">
    <slot />
  </div>
</details>
