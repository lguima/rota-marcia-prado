---
import MetaTags from "@components/MetaTags.astro";
import ThemeSwitcher from "@components/ThemeSwitcher.astro";
import Analytics from "@components/Analytics.astro";
import site from "@config/site.mjs";

const { title, description = site.metadata.description } = Astro.props

const pageTitle = title ? `${title} | ${site.name}` : site.name;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{pageTitle}</title>
  <meta name="description" content={description} />

  <MetaTags title={pageTitle} description={description} />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={site.name} href={new URL("rss.xml", Astro.site)} />

  <slot name="structured-data" />

  <ThemeSwitcher />
  <Analytics />
</head>
