---
import SiteOptions from "../site.config.mjs"
export interface Props {
  page: {
    data: any[]
    url: {
      current: string
      next?: string
      prev?: string
    }
    currentPage: number
    lastPage: number
    size: number
    total: number
  }
}

const { page } = Astro.props
---

<nav class="flex justify-center items-center space-x-4 mt-12" aria-label="Pagination Navigation">
  <!-- Previous Button -->
  {
    SiteOptions.pagination.showPrevNext &&
      (page.url.prev ? (
        <a
          href={page.url.prev}
          class="px-4 py-2 text-sm font-medium text-mist-600 dark:text-mist-400 hover:text-mist-900 dark:hover:text-mist-100 border border-gray-300 dark:border-gray-600 rounded-md hover:border-gray-400 dark:hover:border-gray-500 transition-colors" aria-label="Ir para a página anterior"
        >
          ← {SiteOptions.pagination.prevText}
        </a>
      ) : (
        <span class="px-4 py-2 text-sm font-medium text-mist-400 dark:text-mist-600 border border-mist-200 dark:border-gray-700 rounded-md cursor-not-allowed">
          ← {SiteOptions.pagination.prevText}
        </span>
      ))
  }

  <!-- Page Numbers -->
  <div class="flex items-center space-x-2">
    {
      Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => {
        const isCurrentPage = pageNum === page.currentPage
        const pageUrl = pageNum === 1 ? "/blog/" : `/blog/${pageNum}/`

        return isCurrentPage ? (
          <span
            class="px-3 py-2 text-sm font-medium bg-mist-900 dark:bg-mist-100 text-white dark:text-mist-900 rounded-md"
            aria-current="page"
          >
            {pageNum}
          </span>
        ) : (
          <a
            href={pageUrl}
            class="px-3 py-2 text-sm font-medium text-mist-600 dark:text-mist-400 hover:text-mist-900 dark:hover:text-mist-100 hover:bg-mist-100 dark:hover:bg-mist-800 rounded-md transition-colors"
            aria-label={`Ir para a página ${pageNum}`}
          >
            {pageNum}
          </a>
        )
      })
    }
  </div>

  <!-- Next Button -->
  {
    SiteOptions.pagination.showPrevNext &&
      (page.url.next ? (
        <a
          href={page.url.next}
          class="px-4 py-2 text-sm font-medium text-mist-600 dark:text-mist-400 hover:text-mist-900 dark:hover:text-mist-100 border border-gray-300 dark:border-gray-600 rounded-md hover:border-gray-400 dark:hover:border-gray-500 transition-colors"
          aria-label="Ir para a próxima página"
        >
          {SiteOptions.pagination.nextText} →
        </a>
      ) : (
        <span class="px-4 py-2 text-sm font-medium text-mist-400 dark:text-mist-600 border border-mist-200 dark:border-gray-700 rounded-md cursor-not-allowed">
          {SiteOptions.pagination.nextText} →
        </span>
      ))
  }
</nav>

<!-- Pagination Info -->
<div class="text-center mt-4 text-sm text-mist-500 dark:text-mist-400">
  Mostrando {(page.currentPage - 1) * page.size + 1} a {Math.min(page.currentPage * page.size, page.total)} de {page.total} {SiteOptions.pagination.postLabel}
</div>
