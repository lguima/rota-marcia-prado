---
import analytics from "@config/analytics.mjs";

const isProd = import.meta.env.PROD;
---

{analytics.googleTag.enabled && isProd && (
  <script
    data-category="analytics"
    is:inline
    type="text/partytown"
    async
    src={`https://www.googletagmanager.com/gtag/js?id=${analytics.googleTag.measurementId}`}
  ></script>

  <script
    data-category="analytics"
    is:inline
    type="text/partytown"
    define:vars={{googleTagMeasurementId: analytics.googleTag.measurementId}}
  >
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', googleTagMeasurementId);
  </script>
)}
