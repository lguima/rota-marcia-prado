---
import BlogLayout from "@layouts/BlogLayout.astro"
import Header from "@components/Header.astro"
import Footer from "@components/Footer.astro"
import ListExpand from "@components/molecules/ListExpand.astro"

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "O que é a Rota Márcia Prado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "É uma rota cicloturística que liga a Região Metropolitana de São Paulo a Santos pela Serra do Mar, conhecida como a tradicional descida de Santos. É uma rota popular entre ciclistas que desejam descer a serra de bicicleta, aproveitando a paisagem e a experiência única do trajeto."
      }
    },
    {
      "@type": "Question",
      "name": "Quem foi Márcia Prado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Márcia Regina de Andrade Prado (17 de setembro de 1968 - 14 de janeiro de 2009, São Paulo) foi fisioterapeuta, ciclista urbana, cicloturista e uma importante defensora da mobilidade por bicicleta em São Paulo. Participante ativa da Bicicletada (Massa Crítica), dedicava-se à promoção de um trânsito mais seguro e ao incentivo do uso da bicicleta como meio de transporte e lazer. Em 14 de janeiro de 2009, foi atropelada e morta por um ônibus enquanto pedalava na capital paulista. Sua morte tornou-se um marco na luta pelos direitos das pessoas que pedalam e inspirou a criação da Rota Márcia Prado, que homenageia seu legado em defesa da mobilidade ativa e da preservação ambiental."
      }
    },
    {
      "@type": "Question",
      "name": "Qual é a distância total?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Rota Márcia Prado oficial tem aproximadamente 87 km de extensão, medidos desde o estacionamento da Ciclovia da Marginal Pinheiros (Av. Miguel Yunes) até Santos."
      }
    },
    {
      "@type": "Question",
      "name": "Onde começa o trajeto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O início oficial fica no estacionamento da ciclovia da Marginal Pinheiros (próximo a Interlagos)."
      }
    },
    {
      "@type": "Question",
      "name": "Onde termina a rota?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O destino final é a orla da praia de Santos, tradicionalmente na Praia do José Menino (Canal 1)."
      }
    },
    {
      "@type": "Question",
      "name": "A rota é só descida?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Não. O trajeto acumula mais de 1.000 metros de subida antes de chegar ao trecho da serra."
      }
    },
    {
      "@type": "Question",
      "name": "Como é dividida a altimetria?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "São cerca de 44 km de planalto com subidas e descidas, seguidos por 17 km de descida de serra e 20 km planos na Baixada."
      }
    },
    {
      "@type": "Question",
      "name": "Passa por rodovias movimentadas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Não. A rota oficial foi desenhada justamente para evitar o tráfego pesado e o perigo das rodovias Anchieta e Imigrantes."
      }
    },
    {
      "@type": "Question",
      "name": "É preciso pegar balsa no caminho?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim, o roteiro exige a travessia de duas balsas gratuitas na Represa Billings: a do Grajaú (Ilha do Bororé) e a de Taquacetuba."
      }
    },
    {
      "@type": "Question",
      "name": "Como é feita a descida da serra?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A descida ocorre pela Estrada de Manutenção da Rodovia dos Imigrantes, uma via asfaltada fechada para o tráfego regular de veículos."
      }
    },
    {
      "@type": "Question",
      "name": "Qual é o tipo de terreno da rota?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Misto. O percurso inclui ciclovias urbanas, asfalto nas estradas de manutenção e cerca de 16 km de estradas de terra batida."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto tempo leva para completar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende do ritmo, mas ciclistas de nível intermediário costumam fazer o trajeto entre 5 e 7 horas, incluindo as paradas."
      }
    },
    {
      "@type": "Question",
      "name": "Como voltar de Santos para São Paulo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Muitos utilizam vans de turismo especializadas em ciclistas ou retornam de ônibus rodoviário."
      }
    },
    {
      "@type": "Question",
      "name": "Qual é o nível de dificuldade física?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "É classificado como intermediário. Recomenda-se que a pessoa já tenha o hábito de pedalar distâncias longas com regularidade."
      }
    },
    {
      "@type": "Question",
      "name": "Qual o tipo de bicicleta ideal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As bicicletas do tipo Mountain Bike (MTB) ou Gravel são as mais recomendadas devido aos trechos de terra, cascalho e eventuais buracos."
      }
    },
    {
      "@type": "Question",
      "name": "Qual o item mecânico mais exigido?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Os freios. Eles precisam passar por uma revisão rigorosa antes de ir, pois serão muito exigidos nos 17 km contínuos de descida da serra."
      }
    },
    {
      "@type": "Question",
      "name": "A rota é bem sinalizada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Há sinalização não oficial feita por pessoas voluntárias. Recomenda-se o uso de GPS ou aplicativos como o Wikiloc."
      }
    },
    {
      "@type": "Question",
      "name": "É seguro pedalar sozinho?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recomenda-se fortemente pedalar em grupos devido a trechos isolados na mata e para auxílio mútuo em caso de quebras ou furos de pneu."
      }
    },
  ]
};
---

<BlogLayout title={`Perguntas Frequentes (FAQ)`} description="Dúvidas frequentes sobre a Rota Márcia Prado respondidas para facilitar a descida de bicicleta de São Paulo a Santos.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="structured-data" />

  <Header showTitle={true} />

  <!-- Light Horizontal Bar -->
  <hr class="border-t border-gray-200 dark:border-gray-700 my-8" />

  <!-- Page Header -->
  <header class="mb-12 text-center">
    <h1 class="text-3xl font-bold tracking-tight mb-4 text-mist-900 dark:text-mist-100">
      Perguntas Frequentes (FAQ)
    </h1>
  </header>

  <main>
    <p class="mb-8">Dúvidas frequentes sobre a Rota Márcia Prado respondidas para facilitar a descida de bicicleta de São Paulo a Santos.</p>

    <ListExpand title="O que é a Rota Márcia Prado?">
      É uma rota cicloturística que liga a Região Metropolitana de São Paulo a Santos pela Serra do Mar, conhecida como a tradicional descida de Santos. É uma rota popular entre ciclistas que desejam descer a serra de bicicleta, aproveitando a paisagem e a experiência única do trajeto.
    </ListExpand>

    <ListExpand title="Quem foi Márcia Prado?">
      Márcia Regina de Andrade Prado (17 de setembro de 1968 - 14 de janeiro de 2009, São Paulo) foi fisioterapeuta, ciclista urbana, cicloturista e uma importante defensora da mobilidade por bicicleta em São Paulo. Participante ativa da Bicicletada (Massa Crítica), dedicava-se à promoção de um trânsito mais seguro e ao incentivo do uso da bicicleta como meio de transporte e lazer. Em 14 de janeiro de 2009, foi atropelada e morta por um ônibus enquanto pedalava na capital paulista. Sua morte tornou-se um marco na luta pelos direitos das pessoas que pedalam e inspirou a criação da Rota Márcia Prado, que homenageia seu legado em defesa da mobilidade ativa e da preservação ambiental.
    </ListExpand>

    <ListExpand title="Qual é a distância total?">
      A Rota Márcia Prado oficial tem aproximadamente 87 km de extensão, medidos desde o estacionamento da Ciclovia da Marginal Pinheiros (Av. Miguel Yunes) até Santos.
    </ListExpand>

    <ListExpand title="Onde começa o trajeto?">
      O início oficial fica no estacionamento da ciclovia da Marginal Pinheiros (próximo a Interlagos).
    </ListExpand>

    <ListExpand title="Onde termina a rota?">
      O destino final é a orla da praia de Santos, tradicionalmente na Praia do José Menino (Canal 1).
    </ListExpand>

    <ListExpand title="A rota é só descida?">
      Não. O trajeto acumula mais de 1.000 metros de subida antes de chegar ao trecho da serra.
    </ListExpand>

    <ListExpand title="Como é dividida a altimetria?">
      São cerca de 44 km de planalto com subidas e descidas, seguidos por 17 km de descida de serra e 20 km planos na Baixada.
    </ListExpand>

    <ListExpand title="Passa por rodovias movimentadas?">
      Não. A rota oficial foi desenhada justamente para evitar o tráfego pesado e o perigo das rodovias Anchieta e Imigrantes.
    </ListExpand>

    <ListExpand title="É preciso pegar balsa no caminho?">
      Sim, o roteiro exige a travessia de duas balsas gratuitas na Represa Billings: a do Grajaú (Ilha do Bororé) e a de Taquacetuba.
    </ListExpand>

    <ListExpand title="Como é feita a descida da serra?">
      A descida ocorre pela Estrada de Manutenção da Rodovia dos Imigrantes, uma via asfaltada fechada para o tráfego regular de veículos.
    </ListExpand>

    <ListExpand title="Qual é o tipo de terreno da rota?">
      Misto. O percurso inclui ciclovias urbanas, asfalto nas estradas de manutenção e cerca de 16 km de estradas de terra batida.
    </ListExpand>

    <ListExpand title="Quanto tempo leva para completar?">
      Depende do ritmo, mas ciclistas de nível intermediário costumam fazer o trajeto entre 5 e 7 horas, incluindo as paradas.
    </ListExpand>

    <ListExpand title="Como voltar de Santos para São Paulo?">
      Muitos utilizam vans de turismo especializadas em ciclistas ou retornam de ônibus rodoviário.
    </ListExpand>

    <ListExpand title="Qual é o nível de dificuldade física?">
      É classificado como intermediário. Recomenda-se que a pessoa já tenha o hábito de pedalar distâncias longas com regularidade.
    </ListExpand>

    <ListExpand title="Qual o tipo de bicicleta ideal?">
      As bicicletas do tipo Mountain Bike (MTB) ou Gravel são as mais recomendadas devido aos trechos de terra, cascalho e eventuais buracos.
    </ListExpand>

    <ListExpand title="Qual o item mecânico mais exigido?">
      Os freios. Eles precisam passar por uma revisão rigorosa antes de ir, pois serão muito exigidos nos 17 km contínuos de descida da serra.
    </ListExpand>

    <ListExpand title="A rota é bem sinalizada?">
      Há sinalização não oficial feita por pessoas voluntárias. Recomenda-se o uso de GPS ou aplicativos como o Wikiloc.
    </ListExpand>

    <ListExpand title="É seguro pedalar sozinho?">
      Recomenda-se fortemente pedalar em grupos devido a trechos isolados na mata e para auxílio mútuo em caso de quebras ou furos de pneu.
    </ListExpand>
  </main>

  <!-- Minimal Footer -->
  <Footer />
</BlogLayout>
